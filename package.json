{
  "name": "university-management-system",
  "version": "1.0.0",
  "description": "University Management Dashboard - PERN Stack",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "build:server": "cd server && npm run build",
    "build:client": "cd client && npm run build",
    "db:generate": "cd server && npm run db:generate",
    "db:migrate": "cd server && npm run db:migrate",
    "db:push": "cd server && npm run db:push",
    "db:seed": "cd server && npm run seed",
    "setup": "npm run install:all && npm run db:push && npm run db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}

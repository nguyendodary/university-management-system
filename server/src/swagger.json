    "/dashboard/stats": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "Get dashboard statistics",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Dashboard stats",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "stats": {
                          "type": "object",
                          "properties": {
                            "totalUsers": { "type": "integer" },
                            "totalStudents": { "type": "integer" },
                            "totalCourses": { "type": "integer" },
                            "totalEnrollments": { "type": "integer" }
                          }
                        },
                        "roleDistribution": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "role": { "type": "string" },
                              "count": { "type": "integer" }
                            }
                          }
                        },
                        "recentEnrollments": {
                          "type": "array",
                          "items": { "$ref": "#/components/schemas/Enrollment" }
                        },
                        "topCourses": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": { "type": "string" },
